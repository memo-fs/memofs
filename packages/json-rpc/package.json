{
	"name": "@memofs/json-rpc",
	"version": "1.1.0-beta.1",
	"private": false,
	"description": "Dependency-free JSON-RPC 2.0 protocol primitives shared by MemoFS transports.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/memo-fs/memofs.git",
		"directory": "packages/json-rpc"
	},
	"homepage": "https://docs.memofs.dev/packages/json-rpc/",
	"bugs": {
		"url": "https://github.com/memo-fs/memofs/issues"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"json-rpc",
		"jsonrpc",
		"json-rpc-2",
		"protocol",
		"rpc",
		"memofs",
		"typescript"
	],
	"engines": {
		"node": ">=22"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	},
	"devDependencies": {
		"@repo/tsdown": "workspace:*",
		"@repo/typescript": "workspace:*"
	}
}
