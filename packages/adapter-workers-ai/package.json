{
	"name": "@memofs/adapter-workers-ai",
	"version": "1.1.0-beta.1",
	"private": false,
	"description": "Cloudflare Workers AI extractor adapter for MemoFS.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/memo-fs/memofs.git",
		"directory": "packages/adapter-workers-ai"
	},
	"homepage": "https://docs.memofs.dev/packages/adapter-workers-ai/",
	"bugs": {
		"url": "https://github.com/memo-fs/memofs/issues"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"cloudflare",
		"workers-ai",
		"llm",
		"extractor",
		"graph",
		"memofs",
		"adapter",
		"typescript"
	],
	"engines": {
		"node": ">=22"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	},
	"dependencies": {
		"@memofs/core": "workspace:^"
	},
	"peerDependencies": {
		"@cloudflare/workers-types": "^4.20250617.0"
	},
	"peerDependenciesMeta": {
		"@cloudflare/workers-types": {
			"optional": true
		}
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250617.0",
		"@repo/tsdown": "workspace:*",
		"@repo/typescript": "workspace:*",
		"@repo/utils": "workspace:*",
		"@memofs/testing": "workspace:^"
	}
}
