{
	"name": "@memofs/server",
	"version": "1.0.0-beta.2",
	"private": false,
	"description": "Self-hostable MemoFS runtime server for Node and Cloudflare Workers deployments.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/christophersesugh/memofs.git",
		"directory": "packages/server"
	},
	"homepage": "https://docs.memofs.dev/packages/server/",
	"bugs": {
		"url": "https://github.com/christophersesugh/memofs/issues"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./worker": {
			"import": {
				"types": "./dist/worker.d.mts",
				"default": "./dist/worker.mjs"
			},
			"require": {
				"types": "./dist/worker.d.cts",
				"default": "./dist/worker.cjs"
			}
		}
	},
	"bin": {
		"memofs-server": "./dist/bin/memofs-server.mjs"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"memory",
		"agents",
		"self-host",
		"runtime",
		"server",
		"memofs",
		"adapter",
		"typescript"
	],
	"engines": {
		"node": ">=22"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	},
	"dependencies": {
		"@memofs/core": "workspace:^",
		"@memofs/json-rpc": "workspace:^"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.17.0",
		"@repo/tsdown": "workspace:*",
		"@repo/typescript": "workspace:*",
		"@memofs/testing": "workspace:^",
		"@types/node": "^25.9.2",
		"vitest": "^4.1.8"
	}
}
