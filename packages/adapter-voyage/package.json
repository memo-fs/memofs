{
	"name": "@memofs/adapter-voyage",
	"version": "1.0.0-beta.2",
	"private": false,
	"description": "Voyage AI embedder and reranker adapter for MemoFS.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/christophersesugh/memofs.git",
		"directory": "packages/adapter-voyage"
	},
	"homepage": "https://docs.memofs.dev/packages/adapter-voyage/",
	"bugs": {
		"url": "https://github.com/christophersesugh/memofs/issues"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./testing": {
			"import": {
				"types": "./dist/testing/index.d.mts",
				"default": "./dist/testing/index.mjs"
			},
			"require": {
				"types": "./dist/testing/index.d.cts",
				"default": "./dist/testing/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"voyage",
		"voyageai",
		"embeddings",
		"reranker",
		"ai",
		"agents",
		"memory",
		"memofs",
		"adapter",
		"typescript"
	],
	"engines": {
		"node": ">=22"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	},
	"dependencies": {
		"@memofs/core": "workspace:^"
	},
	"devDependencies": {
		"@repo/tsdown": "workspace:*",
		"@repo/typescript": "workspace:*",
		"@repo/utils": "workspace:*",
		"@memofs/testing": "workspace:^"
	}
}
