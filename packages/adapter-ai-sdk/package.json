{
	"name": "@memofs/adapter-ai-sdk",
	"version": "1.1.0-beta.1",
	"private": false,
	"description": "Vercel AI SDK adapter for MemoFS memory tools, runtime bridging, and context builders.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/memo-fs/memofs.git",
		"directory": "packages/adapter-ai-sdk"
	},
	"homepage": "https://docs.memofs.dev/packages/adapter-ai-sdk/",
	"bugs": {
		"url": "https://github.com/memo-fs/memofs/issues"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "rm -rf dist coverage .turbo",
		"lint:package": "publint",
		"prepack": "pnpm build",
		"pack:dry-run": "pnpm build && npm pack --dry-run",
		"release:check": "pnpm build && pnpm typecheck && pnpm test:run && pnpm lint:package && npm pack --dry-run"
	},
	"keywords": [
		"ai-sdk",
		"vercel",
		"ai",
		"agents",
		"memory",
		"memofs",
		"adapter",
		"typescript"
	],
	"engines": {
		"node": ">=22"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	},
	"dependencies": {
		"@memofs/core": "workspace:^",
		"zod": "^4.4.2"
	},
	"peerDependencies": {
		"ai": ">=5.0.0 <7.0.0"
	},
	"devDependencies": {
		"@repo/tsdown": "workspace:*",
		"@repo/typescript": "workspace:*",
		"@memofs/testing": "workspace:^"
	}
}
