{
	"$schema": "https://opencode.ai/config.json",
	"references": {
		"memofs-cloud": {
			"path": "../memofs-cloud",
			"description": "Use for MemoFS Cloud app reference and implementation details"
		}
	},
	"mcp": {
		"memofs": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@memofs/mcp-server",
				"--runtime",
				"local",
				"--root",
				"."
			],
			"enabled": true
		}
	}
}
