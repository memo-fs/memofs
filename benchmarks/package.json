{
	"name": "@tekmemo/benchmarks",
	"version": "1.0.0-beta.1",
	"private": true,
	"type": "module",
	"scripts": {
		"smoke": "node --import tsx scripts/run-smoke.ts",
		"release": "node --import tsx scripts/run-release.ts",
		"full": "node --import tsx scripts/run-full.ts",
		"benchmark:smoke": "pnpm smoke",
		"benchmark:release": "pnpm release",
		"benchmark:full": "pnpm full",
		"benchmark:compare": "node --import tsx scripts/compare-baseline.ts",
		"report": "node --import tsx scripts/generate-report.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@tekmemo/core": "workspace:*",
		"@tekmemo/benchmark-kit": "workspace:*"
	},
	"devDependencies": {
		"@repo/typescript": "workspace:*",
		"tsx": "^4.22.4",
		"typescript": "6.0.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tekbreed/tekmemo.git",
		"directory": "benchmarks"
	},
	"description": "Private workspace runner for TekMemo benchmark suites."
}
