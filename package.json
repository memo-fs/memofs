{
	"name": "memofs/dev",
	"version": "0.0.1",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/christophersesugh/memofs.git"
	},
	"scripts": {
		"build": "turbo run build",
		"build:watch": "turbo run build:watch",
		"check": "biome check packages apps benchmarks tooling scripts",
		"sync:cloud": "bash scripts/sync-cloud.sh",
		"sync:cloud:dry": "bash scripts/sync-cloud.sh --dry-run",
		"sync:cloud:no-push": "bash scripts/sync-cloud.sh --no-push",
		"format-and-lint": "biome check .",
		"format-and-lint:fix": "biome check . --write",
		"format-and-lint:fix:unsafe": "biome check . --write --unsafe",
		"typecheck": "turbo run typecheck --filter=./packages/* --filter=./apps/* --filter=./tooling/*",
		"test": "turbo run test:run",
		"test:watch": "turbo run test:watch",
		"test:coverage": "turbo run test:coverage",
		"lint:package": "turbo run lint:package",
		"benchmark:smoke": "turbo run benchmark:smoke --filter=@memofs/benchmarks",
		"benchmark:release": "turbo run benchmark:release --filter=@memofs/benchmarks",
		"benchmark:full": "turbo run benchmark:full --filter=@memofs/benchmarks",
		"benchmark:compare": "turbo run benchmark:compare --filter=@memofs/benchmarks",
		"release:check": "pnpm run ci",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"ci": "pnpm check && pnpm typecheck && pnpm test && pnpm build && pnpm lint:package && pnpm docs:build",
		"docs:dev": "pnpm --filter @memofs/docs dev",
		"docs:build": "pnpm --filter @memofs/docs build",
		"docs:preview": "pnpm --filter @memofs/docs preview",
		"packages:build": "turbo run build --filter=./packages/*",
		"packages:test": "turbo run test:run --filter=./packages/*",
		"release:dry-run": "pnpm -r publish --dry-run",
		"validate:workspace": "pnpm check && pnpm typecheck && pnpm test && pnpm build && pnpm lint:package && pnpm docs:build",
		"validate:packages": "pnpm lint:package && pnpm packages:build",
		"validate:docs": "pnpm docs:check && pnpm docs:build",
		"validate:release": "pnpm validate:workspace && pnpm release:dry-run",
		"docs:check": "pnpm --filter @memofs/docs check",
		"pack:dry-run": "turbo run pack:dry-run --filter=./packages/*",
		"release:package-check": "turbo run release:check --filter=./packages/*",
		"release:preflight": "pnpm validate:workspace && pnpm release:package-check && pnpm release:dry-run",
		"publish:docs": "pnpm docs:build",
		"validate:publish": "pnpm release:preflight"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@changesets/types": "^6.1.0",
		"@memofs/mcp-server": "workspace:^",
		"@memofs/cli": "workspace:^",
		"@types/node": "^25.9.2",
		"@vitest/coverage-v8": "^4.1.8",
		"dotenv": "^17.4.2",
		"publint": "^0.3.21",
		"tsdown": "^0.22.2",
		"tsx": "^4.22.4",
		"turbo": "^2.9.16",
		"typescript": "6.0.3",
		"vitest": "^4.1.8",
		"zod": "^4.4.3"
	},
	"packageManager": "pnpm@9.15.4",
	"engines": {
		"node": ">=22",
		"pnpm": ">=9.0.0"
	},
	"description": "MemoFS — open-source file-first memory runtime for AI applications and agents.",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/christophersesugh/memofs/issues"
	},
	"homepage": "https://docs.memofs.dev/",
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/christophersesugh"
	}
}
