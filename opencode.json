{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"tekmemo": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@tekmemo/mcp-server",
				"--runtime",
				"local",
				"--root",
				"."
			],
			"enabled": true
		}
	},
	"references": {
		"tekbreed-local": {
			"path": "../workspace",
			"description": "use this whenever you need any details about tekbreed local"
		}
	}
}
