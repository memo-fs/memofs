{
	"extends": "@repo/typescript/base.json",
	"compilerOptions": {
		"types": ["node", "vitepress/client"],
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": [
		".vitepress/**/*.ts",
		".vitepress/**/*.mts",
		".vitepress/**/*.vue",
		"scripts/**/*.mjs"
	]
}
