{
	"extends": "./tsconfig.build.json",
	"include": [
		".react-router/types/**/*",
		"src/**/*",
		"src/**/.server/**/*",
		"src/**/.client/**/*",
		"workers/**/*",
		"worker-configuration.d.ts",
		"src/.server",
		"tests/utils/db.ts",
		"tests/utils/env.ts"
	],
	"compilerOptions": {
		"composite": true,
		"emitDeclarationOnly": true,
		"declarationDir": "./.typecheck",
		"skipLibCheck": true,
		"strict": true,
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["vite/client"],
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"rootDirs": [".", "./.react-router/types"],
		"paths": {
			"~/*": ["./src/*"]
		},
		"esModuleInterop": true,
		"resolveJsonModule": true
	}
}
