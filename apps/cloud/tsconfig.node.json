{
	"extends": "./tsconfig.build.json",
	"include": ["tailwind.config.ts", "vite.config.ts"],
	"compilerOptions": {
		"composite": true,
		"emitDeclarationOnly": true,
		"declarationDir": "./.typecheck",
		"skipLibCheck": true,
		"strict": true,
		"types": ["node"],
		"lib": ["ES2022"],
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler"
	}
}
