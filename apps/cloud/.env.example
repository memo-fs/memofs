# TekMemo Cloud — environment variables.
#
# Copy this file to `.env` (gitignored) and fill in real values.
# Only `DATABASE_URL` is required for `drizzle-kit generate` (offline SQL
# generation — drizzle-kit does NOT connect to a live DB at generate time).
# The Worker itself reads bindings from `wrangler.jsonc` + `wrangler secret`,
# NEVER from this file — see `src/server/env.ts`.
#
# Turso/libSQL (metadata DB). Create a free DB at https://turso.tech.
DATABASE_URL=libsql://<your-db>.turso.io
DATABASE_AUTH_TOKEN=

# R2 S3-compatible API (for presigning PUT/GET). Cloudflare dashboard → R2 →
# "Manage R2 API Tokens". Leave blank to use the `BLOBS` binding directly.
R2_S3_ACCESS_KEY_ID=
R2_S3_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=<accountId>.r2.cloudflarestorage.com
R2_BUCKET_NAME=tekmemo-blobs

# HMAC salt for API-key hashing (Worker secret in prod; any random string in dev).
TEKMEMO_API_KEY_SALT=

# Dashboard session cookie secret (any 32+ char random string in dev).
SESSION_SECRET=
